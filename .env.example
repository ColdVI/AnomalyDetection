# STORAGE_BACKEND=local skips MinIO entirely and writes Bronze/Silver/Gold to disk
# under LOCAL_STORAGE_DIR -- use this until docker-compose (Kafka/MinIO) is set up.
STORAGE_BACKEND=minio
LOCAL_STORAGE_DIR=data/objectstore

ADSBLOL_API_KEY=
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=uav.raw.states
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BRONZE_BUCKET=bronze
MINIO_SILVER_BUCKET=silver
MINIO_GOLD_BUCKET=gold

# Dashboard/adsb_producer.py -- ayni Wi-Fi/LAN'daki bir takim arkadasinin
# bu makinenin Kafka'sina baglanabilmesi icin (bkz. docker-compose.yml
# kafka servisi). Bos birakilirsa "localhost" kullanilir (sadece bu
# makineden erisim).
KAFKA_LAN_HOST=

# opensky-network.org hesap ayarlarindan (OAuth2 client). Bos birakilirsa
# producer anonim erisime duser (gunde 400 kredi, 300sn araliga zorlanir).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
